---
import clsx from "clsx";
import Navbar from "../components/Navbar.astro";
import Layout from "../layouts/Layout.astro";

const people = [
	{
		name: "Kaki87",
		description: "Kaki helped me with my first programs, and answered all my tech questions for years.",
		avatarUrl: "kaki87.png",
		link: "https://kaki87.net"
	},
	{
	    name: "Alex'Presso",
	    description: "Patiently taught me OOP and Node.js through Discord DMs back when I was 13.",
		avatarUrl: "alex.jpg",
		link: "http://alexpresso.me/"
	},
	{
	    name: "Fabnem",
	    description: "One of the main reasons I made it through my first year of CS! Always helpful and kind.",
		avatarUrl: "fabnem.png",
		link: "https://fabnem.dev/"
	},
	{
		name: "Loggerz",
		description: "Loggerz is still teaching me how to use K8S and answer all my infrastructure/cloud questions.",
		avatarUrl: "loggerz.png",
		link: "https://loggerz.net"
	},
	{
		name: "Picnixz",
		description: "Picnixz taught me how to use OpenSUSE and understand better how Linux works.",
		avatarUrl: "picnixz.png",
		link: "https://github.com/picnixz"
	},
	{
		name: "AllElectric2030",
		subname: "(✝ 2024)",
		description: "AllElectric2030 was an amazing friend and mentor, knowledgeable in so many fields. Rest in peace.",
		avatarUrl: "allelectric2030.png"
	},
	{
		name: "Johnny",
		description: "Johnny saved my Linux from my configuration mistakes twice in less than 2 months. Made me discover i3 and how to use a computer properly.",
		avatarUrl: "jneos.png",
		link: "https://people.epfl.ch/johnny.kalajdzic"
	},
	{
	    name: "Nicolas",
	    description: "Pushed me toward a few major life choices that ended up making me happier. Endlessly knowledgeable and deeply passionate about CS.",
		avatarUrl: "nettlin.jpg",
		link: "https://nicolas.ettlin.dev/"
	}
]

const nameGradientClasses = clsx([
	"font-black",
	"bg-gradient-to-b",
	"from-violet-600",
	"to-teal-600",
	"bg-clip-text",
	"bg-[length:100%_300%]",
	"bg-left",
	"text-transparent",
	"animate-bg-pulse",
]);

---

<Layout title="Blog">
	<div class="container mx-auto w-full px-4">
		<Navbar />
		<div class="flex flex-col gap-2">
			<div>
				<h1 class="text-4xl font-bold">Wall of Fame</h1>
				<p class="text-lg text-stone-600 dark:text-stone-400">
                    These are the talented people who spent countless hours mentoring me and helping me grow in CS. Finding mentors like them is rare, and I'm beyond grateful our paths crossed. Note: this wall is not about friends, though some have become very close ones.
				</p>
				<hr class="my-4 border-stone-200 dark:border-stone-600" />
			</div>
			<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
				{people.map((person) => (
					<div class="grid md:grid-cols-3 bg-white dark:bg-stone-800 rounded-lg p-4 shadow-md">
						<div class="rounded-full overflow-hidden">
							<img
								src={`/assets/wall/${person.avatarUrl}`}
								alt={person.name}
								class="w-full h-full object-cover"
							/>
						</div>
						<div class="col-span-2 m-4">
							<div class="flex items-center gap-2">
								<a href={person.link} class="text-2xl font-bold text-stone-600 dark:text-stone-400 hover:underline">
									<span class={nameGradientClasses}>{person.name}</span>
								</a>
								{person.subname && (
									<p class="text-stone dark:text-stone-400">{person.subname}</p>
								)}
							</div>
							<p class="text-stone-600 dark:text-stone-400">{person.description}</p>
						</div>
					</div>
				))}
			</div>
		</div>
	</div>
</Layout>
